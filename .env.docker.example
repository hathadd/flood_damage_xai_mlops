# Docker Compose Environment Variables
# File: .env.docker (DO NOT commit sensitive data)
# Usage: docker compose --env-file .env.docker up

# ========================================
# FastAPI Model Loading Configuration
# ========================================

# Model source strategy:
# - "auto": Try MLflow Registry first, fallback to checkpoint
# - "mlflow_registry": Only MLflow Registry
# - "local_checkpoint": Only local checkpoint
FLOOD_DAMAGE_MODEL_SOURCE=auto

# MLflow Registry Location
# Local file-based (docker-compose):
MLFLOW_TRACKING_URI=./mlruns

# For Kubernetes/Production (use remote registry):
# MLFLOW_TRACKING_URI=http://mlflow-server:5000
# or AWS S3: MLFLOW_TRACKING_URI=s3://bucket/mlruns

# Model identification in registry
FLOOD_DAMAGE_REGISTERED_MODEL_NAME=flood_damage_siamese_resnet18
FLOOD_DAMAGE_MODEL_ALIAS=champion

# Fallback checkpoint path (relative to /app in container)
FLOOD_DAMAGE_CHECKPOINT_PATH=outputs/focal_run_b_regularized/checkpoints/best_siamese_resnet18.pt

# Device selection
# - "auto": Use GPU if available, else CPU
# - "cuda": Force GPU
# - "cpu": Force CPU
FLOOD_DAMAGE_DEVICE=auto

# ========================================
# Streamlit Configuration
# ========================================

# API base URL (from Streamlit perspective)
# Local: http://127.0.0.1:8000
# Docker Compose: http://api:8000
# Kubernetes: http://flood-api:8000
FLOOD_DAMAGE_API_BASE_URL=http://api:8000

# ========================================
# Optional: Python Environment
# ========================================

# Prevent Python bytecode generation (already in Dockerfile)
PYTHONDONTWRITEBYTECODE=1

# Unbuffered output (already in Dockerfile)
PYTHONUNBUFFERED=1

# Application path (already in Dockerfile)
PYTHONPATH=/app
